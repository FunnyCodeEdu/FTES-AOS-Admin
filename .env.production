# Base URL API cho production build (Vercel `vite build` đọc file này — `.env` bị gitignore
# nên KHÔNG có trên Vercel → API_ROOT rỗng → request rơi vào origin Vercel → 404).
# Có thể override bằng biến môi trường VITE_API_BASE_URL trong Vercel Project Settings.
VITE_API_BASE_URL=https://apitest.ftes.vn
